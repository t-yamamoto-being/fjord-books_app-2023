<div id="<%= dom_id report %>">
  <p>
    <strong><%= Report.human_attribute_name(:title) %>:</strong>
    <%= report.title %>
  </p>

  <p>
    <strong><%= Report.human_attribute_name(:author) %>:</strong>
    <%= report.author %>
  </p>

  <p>
    <strong><%= Report.human_attribute_name(:posted_date) %>:</strong>
    <%= report.created_at.to_date %>
  </p>

  <p>
    <strong><%= Report.human_attribute_name(:content) %>:</strong>
    <%= report.content %>
  </p>

</div>
